layout {
    pane size=1 borderless=true {
        plugin location="tab-bar"
    }

    pane split_direction="vertical" {
        pane
    }

    // Single bottom row: left = Zellij command hints, right = custom system metrics.
    pane size=1 split_direction="vertical" {
        pane size="40%" borderless=true {
            plugin location="status-bar"
        }

        pane borderless=true {
            plugin location="file:/Users/abhishek/.config/zellij/plugins/zjstatus.wasm" {
                format_left   ""
                format_center ""
                format_right  "{pipe_sysbar}{datetime}"
                format_space  "#[bg=#111111]"

                border_enabled  "false"
                border_char     "─"
                border_format   "#[fg=#3d4056]{char}"
                border_position "top"

                hide_frame_for_single_pane "false"

                // Metrics are pushed by zsysbar-daemon via:
                //   zellij pipe --name pipe_sysbar -- "<formatted string>"
                // No command is spawned by zellij for this widget.
                pipe_sysbar_format     "#[fg=#ffb86c,bg=#111111,bold] {output} "
                pipe_sysbar_rendermode "dynamic"

                // Clock rendered by the plugin itself (no shell-out).
                datetime          "#[fg=#ffb86c,bg=#111111,bold] {format} "
                datetime_format   "%Y-%m-%d %H:%M:%S"
            }
        }
    }
}
