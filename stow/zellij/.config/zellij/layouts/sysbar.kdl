layout {
    pane size=1 borderless=true {
        plugin location="tab-bar"
    }

    pane split_direction="vertical" {
        pane
    }

    // Single bottom row: left = Zellij command hints, right = custom system metrics.
    pane size=1 split_direction="vertical" {
        pane size="40%" borderless=true {
            plugin location="status-bar"
        }

        pane borderless=true {
            plugin location="file:/Users/abhishek/.config/zellij/plugins/zjstatus.wasm" {
                format_left   ""
                format_center ""
                format_right  "{command_sysbar}"
                format_space  "#[bg=#111111]"

                border_enabled  "false"
                border_char     "─"
                border_format   "#[fg=#3d4056]{char}"
                border_position "top"

                hide_frame_for_single_pane "false"

                command_sysbar_command    "/Users/abhishek/.config/zellij/scripts/statusbar.sh"
                command_sysbar_format     "{stdout}"
                command_sysbar_interval   "1"
                command_sysbar_rendermode "dynamic"
            }
        }
    }
}
