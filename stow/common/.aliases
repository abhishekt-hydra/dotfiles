alias c="clear"

# Create a new directory and enter it.
mkcd() {
  mkdir -p "$1"
  cd "$1" || return
}

# Extract various archive formats.
extract() {
  if [[ -f "$1" ]]; then
    case "$1" in
      *.tar.bz2) tar xjf "$1" ;;
      *.tar.gz)  tar xzf "$1" ;;
      *.bz2)     bunzip2 "$1" ;;
      *.rar)     unrar e "$1" ;;
      *.gz)      gunzip "$1" ;;
      *.tar)     tar xf "$1" ;;
      *.tbz2)    tar xjf "$1" ;;
      *.tgz)     tar xzf "$1" ;;
      *.zip)     unzip "$1" ;;
      *.Z)       uncompress "$1" ;;
      *.7z)      7z x "$1" ;;
      *)         echo "'$1' cannot be extracted via extract()" ;;
    esac
  else
    echo "'$1' is not a valid file"
  fi
}

# Keep private exports/API keys out of git.
[[ -f "$HOME/.secrets" ]] && source "$HOME/.secrets"

# List top files/folders in the current directory.
big() {
  echo "==== Total Directory Size ===="
  du -sh .
  echo ""
  echo "==== Top 20 Biggest Folders ===="
  du -ah . | sort -rh | head -n 20
  echo ""
  echo "==== Top 20 Biggest Files ===="
  find . -type f -exec du -h {} + | sort -rh | head -n 20
}

alias rsync="rsync -Pav"

brewup() {
  arch -arm64 /opt/homebrew/bin/brew update && \
    arch -arm64 /opt/homebrew/bin/brew upgrade && \
    command -v claude >/dev/null 2>&1 && claude update
}

# QMD: force CPU mode to avoid local Metal/node-llama-cpp crashes.
export QMD_FORCE_CPU=1
alias qmdmcp="QMD_FORCE_CPU=1 qmd mcp --http --daemon"

# Create a GitHub PR from the current branch to staging.
# Usage: prstaging [custom body]
# Defaults title to the latest commit subject and body to the latest commit message.
prstaging() {
  local branch title body
  branch="$(git branch --show-current)" || return
  if [[ -z "$branch" ]]; then
    echo "prstaging: not on a branch"
    return 1
  fi

  title="$(git log -1 --pretty=%s)" || return
  body="$*"
  if [[ -z "$body" ]]; then
    body="$(git log -1 --pretty=%B)" || return
  fi

  gh auth switch --hostname github.com --user abhishekt-hydra || return
  git push -u origin "$branch" || return
  gh pr create --base staging --head "$branch" --title "$title" --body "$body"
}

alias pr=prstaging
export HOMEBREW_NO_AUTO_UPDATE=1
