alias c="clear"

# Create a new directory and enter it.
mkcd() {
  mkdir -p "$1"
  cd "$1" || return
}

# Extract various archive formats.
extract() {
  if [[ -f "$1" ]]; then
    case "$1" in
      *.tar.bz2) tar xjf "$1" ;;
      *.tar.gz)  tar xzf "$1" ;;
      *.bz2)     bunzip2 "$1" ;;
      *.rar)     unrar e "$1" ;;
      *.gz)      gunzip "$1" ;;
      *.tar)     tar xf "$1" ;;
      *.tbz2)    tar xjf "$1" ;;
      *.tgz)     tar xzf "$1" ;;
      *.zip)     unzip "$1" ;;
      *.Z)       uncompress "$1" ;;
      *.7z)      7z x "$1" ;;
      *)         echo "'$1' cannot be extracted via extract()" ;;
    esac
  else
    echo "'$1' is not a valid file"
  fi
}

# Keep private exports/API keys out of git.
[[ -f "$HOME/.secrets" ]] && source "$HOME/.secrets"

# List top files/folders in the current directory.
big() {
  echo "==== Total Directory Size ===="
  du -sh .
  echo ""
  echo "==== Top 20 Biggest Folders ===="
  du -ah . | sort -rh | head -n 20
  echo ""
  echo "==== Top 20 Biggest Files ===="
  find . -type f -exec du -h {} + | sort -rh | head -n 20
}

alias rsync="rsync -Pav"

brewup() {
  brew update && brew upgrade && command -v claude >/dev/null 2>&1 && claude update
}

# QMD: force CPU mode to avoid local Metal/node-llama-cpp crashes.
export QMD_FORCE_CPU=1
alias qmdmcp="QMD_FORCE_CPU=1 qmd mcp --http --daemon"
