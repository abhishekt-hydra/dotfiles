[include]
    path = ~/.gitconfig.local

[init]
    defaultBranch = main

[pull]
    rebase = true

[push]
    autoSetupRemote = true

[core]
    editor = nvim
    excludesfile = ~/.gitignore_global

[color]
    ui = auto

[alias]
    co = checkout
    br = branch
    ci = commit
    st = status --short --branch
    lg = log --graph --pretty=format:'%C(yellow)%h%Creset %Cgreen(%cr)%Creset %C(bold blue)<%an>%Creset %s%C(auto)%d%Creset' --abbrev-commit
