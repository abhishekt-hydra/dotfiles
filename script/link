#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."
DOTFILES_ROOT="$(pwd -P)"
BACKUP_TS="${DOTFILES_BACKUP_TS:-$(date +%Y%m%d%H%M%S)}"

if ! command -v stow >/dev/null 2>&1; then
  echo "GNU Stow is required. Run ./install.sh macos or ./install.sh linux first." >&2
  exit 1
fi

if [[ $# -eq 0 ]]; then
  set -- common
fi

same_target() {
  local src="$1" dst="$2"

  [[ -L "$dst" ]] || return 1

  if command -v realpath >/dev/null 2>&1; then
    [[ "$(realpath "$dst" 2>/dev/null || true)" == "$(realpath "$src" 2>/dev/null || true)" ]]
  else
    [[ "$(readlink "$dst" 2>/dev/null || true)" == "$src" ]]
  fi
}

backup_existing() {
  local target="$1"
  local backup="${target}.backup.${BACKUP_TS}"
  local i=1

  while [[ -e "$backup" || -L "$backup" ]]; do
    backup="${target}.backup.${BACKUP_TS}.${i}"
    i=$((i + 1))
  done

  mv "$target" "$backup"
  echo "Backed up $target -> $backup"
}

prepare_package() {
  local package="$1"
  local package_root="$DOTFILES_ROOT/stow/$package"
  local src rel dst

  while IFS= read -r -d '' src; do
    rel="${src#$package_root/}"
    dst="$HOME/$rel"

    if [[ -e "$dst" || -L "$dst" ]]; then
      if same_target "$src" "$dst"; then
        continue
      fi
      backup_existing "$dst"
    fi
  done < <(find "$package_root" \( -type f -o -type l \) -print0)
}

for package in "$@"; do
  if [[ -d "$DOTFILES_ROOT/stow/$package" ]]; then
    echo "Preparing stow/$package -> $HOME"
    prepare_package "$package"
    echo "Linking stow/$package -> $HOME"
    stow --dir "$DOTFILES_ROOT/stow" --target "$HOME" --verbose --restow "$package"
  else
    echo "Skipping missing stow package: $package"
  fi
done
