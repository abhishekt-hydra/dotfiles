#!/usr/bin/env bash
set -euo pipefail

SSH_DIR="${SSH_DIR:-$HOME/.ssh}"
CONFIG="$SSH_DIR/config"
CONFIG_D="$SSH_DIR/config.d"
MANAGED_CONFIG="$CONFIG_D/dotfiles-github.conf"
BACKUP_TS="${DOTFILES_BACKUP_TS:-$(date +%Y%m%d%H%M%S)}"
GENERATE_KEYS=true
PRINT_KEYS=true

usage() {
  cat <<'EOF'
Usage: ./script/ssh [--no-keys] [--no-print]

Non-destructively sets up SSH config for the repo's personal/work GitHub split.

What it does:
  - ensures ~/.ssh/config includes ~/.ssh/config.d/*.conf
  - writes ~/.ssh/config.d/dotfiles-github.conf for missing GitHub host aliases
  - generates missing keys only when absent:
      ~/.ssh/id_ed25519_personal
      ~/.ssh/id_ed25519_hydra
  - backs up any file before editing it: file.backup.YYYYMMDDHHMMSS
  - prints public keys to add to GitHub
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --no-keys) GENERATE_KEYS=false ;;
    --no-print) PRINT_KEYS=false ;;
    -h|--help) usage; exit 0 ;;
    *) echo "Unknown argument: $1" >&2; usage; exit 1 ;;
  esac
  shift
done

backup_copy() {
  local target="$1"
  local backup="${target}.backup.${BACKUP_TS}"
  local i=1

  [[ -e "$target" || -L "$target" ]] || return 0

  while [[ -e "$backup" || -L "$backup" ]]; do
    backup="${target}.backup.${BACKUP_TS}.${i}"
    i=$((i + 1))
  done

  cp -p "$target" "$backup"
  echo "Backed up $target -> $backup"
}

move_aside() {
  local target="$1"
  local backup="${target}.backup.${BACKUP_TS}"
  local i=1

  [[ -e "$target" || -L "$target" ]] || return 0

  while [[ -e "$backup" || -L "$backup" ]]; do
    backup="${target}.backup.${BACKUP_TS}.${i}"
    i=$((i + 1))
  done

  mv "$target" "$backup"
  echo "Moved $target -> $backup"
}

write_if_changed() {
  local target="$1"
  local content="$2"
  local dir tmp

  dir="$(dirname "$target")"
  mkdir -p "$dir"
  tmp="$dir/.tmp.$(basename "$target").$$"

  printf '%s\n' "$content" > "$tmp"
  chmod 600 "$tmp"

  if [[ -e "$target" || -L "$target" ]]; then
    if cmp -s "$tmp" "$target"; then
      rm -f "$tmp"
      echo "Already up to date: $target"
      return 0
    fi

    backup_copy "$target"
  fi

  # Use cat so a symlink target is updated instead of replacing the symlink.
  cat "$tmp" > "$target"
  chmod 600 "$target"
  rm -f "$tmp"
  echo "Wrote $target"
}

ensure_ssh_dirs() {
  mkdir -p "$SSH_DIR" "$CONFIG_D"
  chmod 700 "$SSH_DIR"
  chmod 700 "$CONFIG_D"
}

ensure_include() {
  local include_re='^[[:space:]]*Include[[:space:]]+.*\.ssh/config\.d/\*\.conf'
  local existing=""
  local content

  if [[ -f "$CONFIG" ]] && grep -Eq "$include_re" "$CONFIG"; then
    chmod 600 "$CONFIG"
    echo "SSH config include already present: $CONFIG"
    return 0
  fi

  if [[ -f "$CONFIG" ]]; then
    existing="$(cat "$CONFIG")"
  fi

  content="# Dotfiles-managed SSH includes
Include ~/.ssh/config.d/*.conf"

  if [[ -n "$existing" ]]; then
    content="$content

$existing"
  fi

  write_if_changed "$CONFIG" "$content"
}

host_defined_outside_managed() {
  local host="$1"
  local files=()
  local file

  [[ -f "$CONFIG" ]] && files+=("$CONFIG")

  if [[ -d "$CONFIG_D" ]]; then
    while IFS= read -r -d '' file; do
      [[ "$file" == "$MANAGED_CONFIG" ]] && continue
      files+=("$file")
    done < <(find "$CONFIG_D" -maxdepth 1 -type f -name '*.conf' -print0)
  fi

  [[ ${#files[@]} -gt 0 ]] || return 1

  awk -v host="$host" '
    /^[[:space:]]*Host[[:space:]]+/ {
      for (i = 2; i <= NF; i++) {
        if ($i == host) found = 1
      }
    }
    END { exit found ? 0 : 1 }
  ' "${files[@]}"
}

github_host_block() {
  local host="$1"
  local key="$2"

  cat <<EOF
Host $host
    HostName github.com
    User git
    IdentityFile ~/.ssh/$key
    IdentitiesOnly yes
EOF
}

build_managed_config() {
  local content="# Managed by dotfiles/script/ssh.
# GitHub host aliases used by ~/.gitconfig_personal and ~/.gitconfig_work."

  if host_defined_outside_managed "github.com-personal"; then
    content="$content

# github.com-personal is already defined outside this file; not duplicated."
  else
    content="$content

$(github_host_block "github.com-personal" "id_ed25519_personal")"
  fi

  if host_defined_outside_managed "github.com-hydra"; then
    content="$content

# github.com-hydra is already defined outside this file; not duplicated."
  else
    content="$content

$(github_host_block "github.com-hydra" "id_ed25519_hydra")"
  fi

  printf '%s\n' "$content"
}

ensure_key() {
  local name="$1"
  local comment="$2"
  local private="$SSH_DIR/$name"
  local public="$private.pub"

  if [[ -f "$private" ]]; then
    echo "Key already exists: $private"
  else
    if [[ "$GENERATE_KEYS" != "true" ]]; then
      echo "Missing key, skipped generation: $private"
      return 0
    fi

    if ! command -v ssh-keygen >/dev/null 2>&1; then
      echo "ssh-keygen is required to create $private" >&2
      exit 1
    fi

    if [[ -e "$public" || -L "$public" ]]; then
      move_aside "$public"
    fi

    echo "Generating key: $private"
    if [[ -t 0 ]]; then
      ssh-keygen -t ed25519 -C "$comment" -f "$private"
    else
      ssh-keygen -t ed25519 -C "$comment" -f "$private" -N ""
    fi
  fi

  chmod 600 "$private" 2>/dev/null || true

  if [[ ! -f "$public" && -f "$private" ]]; then
    ssh-keygen -y -f "$private" > "$public"
  fi

  [[ -f "$public" ]] && chmod 644 "$public"
}

print_public_key() {
  local label="$1"
  local public="$2"

  if [[ -f "$public" ]]; then
    echo ""
    echo "$label public key ($public):"
    cat "$public"
  fi
}

ensure_ssh_dirs
ensure_include
write_if_changed "$MANAGED_CONFIG" "$(build_managed_config)"

ensure_key "id_ed25519_personal" "personal"
ensure_key "id_ed25519_hydra" "abhishek@hydradb.com"

if [[ "$PRINT_KEYS" == "true" ]]; then
  echo ""
  echo "Add these public keys in GitHub -> Settings -> SSH and GPG keys:"
  print_public_key "Personal GitHub" "$SSH_DIR/id_ed25519_personal.pub"
  print_public_key "Hydra GitHub" "$SSH_DIR/id_ed25519_hydra.pub"
fi

cat <<'EOF'

Test after adding keys to GitHub:
  ssh -T git@github.com-personal
  ssh -T git@github.com-hydra
EOF
